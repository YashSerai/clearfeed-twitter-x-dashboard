# Required for drafting
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=

GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_POLISH_MODEL=gemini-3-flash-preview
# Optional for image generation
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional for posting through the app
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_USER_ID=
X_USER_ACCESS_BEARER_TOKEN=

# Optional for mirrored Telegram approvals
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DATABASE_PATH=./data/marketing.sqlite3
TIMEZONE=America/Vancouver
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STORAGE_STATE=./data/browser/x_storage_state.json
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

# Feed discovery weights and URLs
LIST_1_URL=
LIST_1_WEIGHT=1.0

LIST_2_URL=
LIST_2_WEIGHT=0.9

LIST_3_URL=
LIST_3_WEIGHT=0.85

# Optional home timeline discovery
HOME_TIMELINE_ENABLED=false
HOME_TIMELINE_WEIGHT=0.88
