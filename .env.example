# Core AI provider selection
AI_PROVIDER=vertex
AI_TEXT_MODEL=gemini-3-flash-preview
AI_POLISH_MODEL=gemini-3-flash-preview
# Optional premium model override for original-post batches. Falls back to AI_POLISH_MODEL when blank.
AI_ORIGINALS_MODEL=gemini-2.5-pro
# Optional premium model override for learning-based Voice.md updates. Falls back to AI_ORIGINALS_MODEL, then AI_POLISH_MODEL.
AI_VOICE_REVIEW_MODEL=
# Optional premium model override for archive-based Voice.md synthesis. Falls back to AI_VOICE_REVIEW_MODEL, then AI_ORIGINALS_MODEL.
AI_ARCHIVE_VOICE_MODEL=
# Optional. Leave blank to disable vision-aware tweet image summaries on providers that need a separate model.
AI_VISION_MODEL=
# Optional. Leave blank to disable image generation.
AI_IMAGE_MODEL=gemini-2.5-flash-image

# Vertex provider settings
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI-compatible provider settings
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_TIMEOUT_SECONDS=180

# Optional for Telegram Mini App remote access into the same Clearfeed app
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBAPP_ENABLED=false
TELEGRAM_LEGACY_FORWARDING_ENABLED=false
PUBLIC_BASE_URL=
CLOUDFLARED_AUTO_START=false
CLOUDFLARED_TUNNEL_MODE=quick

DATABASE_PATH=./data/marketing.sqlite3
TIMEZONE=America/Vancouver
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STORAGE_STATE=./data/browser/x_storage_state.json
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
WORKER_MIN_DELAY_MINUTES=25
WORKER_MAX_DELAY_MINUTES=35
# Total candidate alerts allowed into the queue per worker cycle.
WORKER_MAX_CANDIDATES_PER_CYCLE=6
# Original-post batch size per generation run.
WORKER_ORIGINAL_POST_OPTIONS=5
# Daily cap for standalone original drafts.
WORKER_MAX_ORIGINAL_DRAFTS_PER_DAY=5
# How many recent source posts to feed into original-post generation.
WORKER_RECENT_SIGNALS_LIMIT=30
# Max posts to scrape from the home timeline on each cycle.
WORKER_HOMEPAGE_SCRAPE_LIMIT=60
# Max home-timeline posts sent into the LLM ranking pool each cycle.
WORKER_HOMEPAGE_LLM_POOL_SIZE=24
# Max home-timeline candidates allowed into the final queue each cycle.
WORKER_HOMEPAGE_MAX_ALERTS_PER_CYCLE=2
# Voice.md review schedule. Use `manual` to disable automatic proposals and only run from the dashboard.
VOICE_REVIEW_MODE=scheduled
# When scheduled, choose `daily`, `weekly`, or `monthly`.
VOICE_REVIEW_CADENCE=daily

# Feed discovery weights and URLs
LIST_1_URL=
LIST_1_WEIGHT=1.0

LIST_2_URL=
LIST_2_WEIGHT=0.9

LIST_3_URL=
LIST_3_WEIGHT=0.85

# Optional home timeline discovery
HOME_TIMELINE_ENABLED=false
# Raise this above the list weights if you want home feed posts to surface more often.
HOME_TIMELINE_WEIGHT=0.88
